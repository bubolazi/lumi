<IfModule mod_headers.c>
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' http://localhost:3000 https://*.bubolazi.com https://api.bubolazi.com https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://fonts.googleapis.com; object-src 'none';"
</IfModule>
